// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  engineType = "client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum FoodCategory {
  PROTEIN
  CARBS
  LEGUME
  DAIRY
  FRUIT
  VEGETABLE
  FAT_OIL
  SWEETS
  SNACK
  OTHER
}

model Food {
  id               String       @id @default(cuid())
  name             String       @unique
  caloriesPer100g  Float
  proteinPer100g   Float
  category         FoodCategory @default(OTHER)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  mealEntries MealEntry[]
}

enum MealType {
  BREAKFAST
  MORNING_SNACK
  LUNCH
  AFTERNOON_SNACK
  DINNER
}

model MealEntry {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  mealType  MealType @default(BREAKFAST)
  grams     Float

  // Snapshot of the food's nutrition values at the time of logging,
  // so later edits to Food don't retroactively change past entries.
  foodName        String
  caloriesPer100g Float
  proteinPer100g  Float

  foodId String?
  food   Food?   @relation(fields: [foodId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([date])
  @@index([foodId])
}

model WeightEntry {
  id        String   @id @default(cuid())
  date      DateTime @unique @db.Date
  weightKg  Float
  createdAt DateTime @default(now())
}

model Goals {
  id                Int   @id @default(1)
  dailyCalorieGoal  Float
  dailyProteinGoal  Float
}

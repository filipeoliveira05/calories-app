// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider   = "prisma-client"
  output     = "../src/generated/prisma"
  engineType = "client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum FoodCategory {
  PROTEIN
  CARBS
  LEGUME
  DAIRY
  FRUIT
  VEGETABLE
  FAT_OIL
  SWEETS
  SNACK
  OTHER
}

model Food {
  id               String       @id @default(cuid())
  name             String       @unique
  caloriesPer100g  Float
  proteinPer100g   Float
  category         FoodCategory @default(OTHER)
  isLoggedByUnit   Boolean      @default(false)
  unitLabel        String?
  gramsPerUnit     Float?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  mealEntries       MealEntry[]
  recipeIngredients RecipeIngredient[]
}

model Recipe {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ingredients RecipeIngredient[]
}

model RecipeIngredient {
  id       String @id @default(cuid())
  recipeId String
  recipe   Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  foodId   String
  food     Food   @relation(fields: [foodId], references: [id], onDelete: Restrict)

  // Fixed amount for this ingredient — exactly one of these is set,
  // mirroring MealEntry's grams/quantity split (driven by food.isLoggedByUnit).
  grams    Float?
  quantity Float?

  @@index([recipeId])
  @@index([foodId])
}

enum MealType {
  BREAKFAST
  MORNING_SNACK
  LUNCH
  AFTERNOON_SNACK
  DINNER
}

model MealEntry {
  id        String   @id @default(cuid())
  date      DateTime @db.Date
  mealType  MealType @default(BREAKFAST)
  grams     Float

  // Snapshot of the food's nutrition values at the time of logging,
  // so later edits to Food don't retroactively change past entries.
  foodName        String
  caloriesPer100g Float
  proteinPer100g  Float

  // Snapshot of unit info at logging time, only set for unit-based entries.
  // Snapshotted for the same reason as above — editing Food's unit weight
  // later must not change how past entries convert to grams.
  quantity     Float?
  unitLabel    String?
  gramsPerUnit Float?

  foodId String?
  food   Food?   @relation(fields: [foodId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([date])
  @@index([foodId])
}

model WeightEntry {
  id        String   @id @default(cuid())
  date      DateTime @unique @db.Date
  weightKg  Float
  createdAt DateTime @default(now())
}

enum Sex {
  MALE
  FEMALE
}

enum ActivityLevel {
  SEDENTARY
  LIGHT
  MODERATE
  ACTIVE
  VERY_ACTIVE
}

enum WeightGoalType {
  LOSE
  MAINTAIN
  GAIN
}

model Goals {
  id                Int             @id @default(1)
  dailyCalorieGoal  Float
  dailyProteinGoal  Float

  // Profile, used to derive the goals above. All optional so existing
  // rows keep working before a profile is set.
  sex               Sex?
  birthDate         DateTime?       @db.Date
  heightCm          Float?
  activityLevel     ActivityLevel?
  goalType          WeightGoalType?
  goalRateKgPerWeek Float?
  proteinPerKg      Float?

  updatedAt         DateTime        @updatedAt
}
